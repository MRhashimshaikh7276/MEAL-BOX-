<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # admin orders dynamic route
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^admin/orders/[^/]+/?$ /admin/orders/\[orderId\]/index.html [L]
  
  # admin products dynamic route  
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^admin/products/[^/]+/?$ /admin/products/\[id\]/index.html [L]
  
  # product detail
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^product/[^/]+/?$ /product/\[id\]/index.html [L]
  
  # combo detail
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^combo/[^/]+/?$ /combo/\[id\]/index.html [L]
  
  # order success
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^order-success/[^/]+/?$ /order-success/\[orderId\]/index.html [L]
  
  # SPA fallback - all other routes to index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^.*$ /index.html [L]
</IfModule>